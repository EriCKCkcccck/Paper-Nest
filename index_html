<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PaperNest · 文献共享库</title>
  <meta name="description" content="按学科整理、上传与分享有意义的论文。" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div class="ambient ambient-one"></div>
  <div class="ambient ambient-two"></div>

  <header class="topbar">
    <a class="brand" href="#">
      <span class="brand-mark">P</span>
      <span>
        <strong>PaperNest</strong>
        <small>你的个人文献共享库</small>
      </span>
    </a>
    <nav>
      <button class="ghost-btn" id="exportBtn">导出备份</button>
      <label class="ghost-btn import-label">
        导入备份
        <input id="importInput" type="file" accept=".json" hidden />
      </label>
      <button class="settings-btn" id="settingsBtn" aria-label="云端设置">⚙</button>
    </nav>
  </header>

  <main>
    <section class="hero">
      <div class="hero-copy">
        <span class="eyebrow">RESEARCH LIBRARY</span>
        <h1>把值得记住的论文，<br><em>放进一个真正好用的地方。</em></h1>
        <p>按学科分类收藏论文、报告和研究链接。支持本地保存，也可连接 Supabase，实现跨设备同步。</p>
        <div class="hero-actions">
          <button class="primary-btn" id="addPaperHero">＋ 添加第一篇论文</button>
          <button class="secondary-btn" id="scrollSubjects">浏览学科</button>
        </div>
      </div>
      <div class="hero-card">
        <div class="mini-stat">
          <span id="totalCount">0</span>
          <small>篇文献</small>
        </div>
        <div class="mini-stat">
          <span id="subjectCount">6</span>
          <small>个学科</small>
        </div>
        <div class="mini-stat">
          <span id="cloudStatus">本地</span>
          <small>存储模式</small>
        </div>
      </div>
    </section>

    <section class="toolbar" id="subjectsSection">
      <div class="search-wrap">
        <span>⌕</span>
        <input id="searchInput" type="search" placeholder="搜索标题、作者、摘要或标签…" />
      </div>
      <select id="sortSelect" aria-label="排序">
        <option value="newest">最新添加</option>
        <option value="oldest">最早添加</option>
        <option value="title">标题 A–Z</option>
        <option value="year">发表年份</option>
      </select>
      <button class="primary-btn compact" id="addPaperBtn">＋ 添加论文</button>
    </section>

    <section class="subject-grid" id="subjectGrid"></section>

    <section class="library-section">
      <div class="section-heading">
        <div>
          <span class="eyebrow">YOUR COLLECTION</span>
          <h2 id="libraryTitle">全部文献</h2>
        </div>
        <button class="clear-filter" id="clearFilter" hidden>清除筛选 ×</button>
      </div>
      <div class="paper-grid" id="paperGrid"></div>
      <div class="empty-state" id="emptyState">
        <div class="empty-icon">⌁</div>
        <h3>这里还没有文献</h3>
        <p>添加论文、研究报告、网页链接或 PDF，慢慢建立属于你的知识库。</p>
        <button class="primary-btn" id="emptyAddBtn">添加论文</button>
      </div>
    </section>
  </main>

  <footer>
    <span>PaperNest</span>
    <p>Read deeply. Save meaningfully.</p>
  </footer>

  <dialog id="paperDialog">
    <form method="dialog" id="paperForm">
      <div class="dialog-header">
        <div>
          <span class="eyebrow">NEW ENTRY</span>
          <h2 id="dialogTitle">添加论文</h2>
        </div>
        <button class="icon-btn" value="cancel" formnovalidate>×</button>
      </div>

      <input type="hidden" id="paperId" />

      <label>
        论文标题 *
        <input id="titleInput" required placeholder="例如：The Ethics of Price Discrimination" />
      </label>

      <div class="two-col">
        <label>
          学科 *
          <select id="subjectInput" required>
            <option value="chinese">Chinese</option>
            <option value="english">English</option>
            <option value="maths">Maths</option>
            <option value="chemistry">Chemistry</option>
            <option value="psychology">Psychology</option>
            <option value="economics">Economics</option>
          </select>
        </label>
        <label>
          年份
          <input id="yearInput" type="number" min="1500" max="2100" placeholder="2026" />
        </label>
      </div>

      <label>
        作者
        <input id="authorsInput" placeholder="作者之间可用逗号分隔" />
      </label>

      <label>
        论文链接
        <input id="urlInput" type="url" placeholder="https://doi.org/... 或网页链接" />
      </label>

      <label>
        上传 PDF
        <input id="fileInput" type="file" accept=".pdf,application/pdf" />
        <small>本地模式下 PDF 保存在当前浏览器；云端模式下上传至 Supabase Storage。</small>
      </label>

      <label>
        标签
        <input id="tagsInput" placeholder="例如：MDD, CBT, ethics（用逗号分隔）" />
      </label>

      <label>
        摘要 / 你的笔记
        <textarea id="notesInput" rows="5" placeholder="这篇论文为什么有意义？它能用于哪一个论点？"></textarea>
      </label>

      <div class="dialog-actions">
        <button class="ghost-btn" value="cancel" formnovalidate>取消</button>
        <button class="primary-btn" id="savePaperBtn" value="default">保存论文</button>
      </div>
    </form>
  </dialog>

  <dialog id="settingsDialog">
    <form method="dialog" id="settingsForm">
      <div class="dialog-header">
        <div>
          <span class="eyebrow">CLOUD SYNC</span>
          <h2>连接 Supabase</h2>
        </div>
        <button class="icon-btn" value="cancel" formnovalidate>×</button>
      </div>
      <p class="settings-copy">填入你的 Supabase 项目信息后，文献会同步到云端，让你在不同设备访问。配置仅保存在当前浏览器。</p>
      <label>
        Project URL
        <input id="supabaseUrl" placeholder="https://xxxx.supabase.co" />
      </label>
      <label>
        Anon public key
        <textarea id="supabaseKey" rows="4" placeholder="eyJhbGciOi..."></textarea>
      </label>
      <div class="cloud-test" id="cloudTest">当前使用本地存储。</div>
      <div class="dialog-actions spread">
        <button type="button" class="danger-ghost" id="disconnectCloud">断开云端</button>
        <div>
          <button class="ghost-btn" value="cancel" formnovalidate>取消</button>
          <button class="primary-btn" id="saveSettingsBtn" value="default">保存并连接</button>
        </div>
      </div>
    </form>
  </dialog>

  <div class="toast" id="toast"></div>
  <script src="app.js"></script>
</body>
</html>
